{
  "name": "nagaoka-tech-coop-platform",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "prisma:generate": "node scripts/run-with-db-env.mjs prisma generate",
    "build": "npm run prisma:generate && next build",
    "postinstall": "npm run prisma:generate",
    "start": "next start",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:reset": "prisma db push --force-reset && node prisma/seed.js",
    "migrate:deploy": "node scripts/run-with-db-env.mjs prisma migrate deploy",
    "vercel:build": "npm run migrate:deploy && npm run build"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/blob": "^2.3.1",
    "bcryptjs": "^3.0.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "next": "^15.5.12",
    "prisma": "^6.19.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^6.9.3",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  }
}
